{
  "name": "bdwp-nuxt",
  "version": "0.0.1",
  "workspaces": [
    "apps/*"
  ],
  "scripts": {
    "d": "bun run scripts/run-command.ts",
    "dev": "bun run d dev backend,frontend-nuxt",
    "build": "bun run d build backend,frontend-nuxt",
    "preview": "bun run d preview backend,frontend-nuxt",
    "lint": "bun run d lint backend,frontend-nuxt",
    "lint:fix": "bun run d lint:fix backend,frontend-nuxt",
    "typecheck": "bun run d typecheck backend,frontend-nuxt",
    "drizzle": "bun run d drizzle-kit backend",
    "seed": "bun run ./apps/backend/src/database/seed.ts"
  },
  "devDependencies": {
    "@types/bun": "^1.3.6",
    "concurrently": "^9.2.1"
  }
}
