{
  "name": "bdwp-ts",
  "version": "0.0.1",
  "devDependencies": {
    "@types/bun": "^1.3.9",
    "husky": "^9.1.7",
    "@huan_kong/monorepo-commander": "^0.0.1"
  },
  "scripts": {
    "dev": "monorepo-commander dev apps/backend,apps/frontend-vue",
    "build": "monorepo-commander build apps/backend,apps/frontend-vue",
    "preview": "monorepo-commander preview apps/backend,apps/frontend-vue",
    "lint": "monorepo-commander lint apps/backend,apps/frontend-vue",
    "lint:fix": "monorepo-commander lint:fix apps/backend,apps/frontend-vue",
    "typecheck": "monorepo-commander typecheck apps/backend,apps/frontend-vue",
    "drizzle": "bun run --cwd apps/backend drizzle-kit",
    "seed": "bun run --cwd apps/backend seed",
    "prepare": "husky",
    "rebuild": "rimraf node_modules bun.lock ./apps/backend/node_modules ./apps/frontend-vue/node_modules"
  },
  "workspaces": [
    "apps/*"
  ]
}
